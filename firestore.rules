rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default global safety net deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // User profile rule match
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
